DJANGO_SECRET_KEY=replace-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=*
CORS_ALLOWED_ORIGINS=http://localhost:5173
CSRF_TRUSTED_ORIGINS=
FASTAPI_URL=http://localhost:8001

# Traceability provider: mock | serpapi
TRACEABILITY_PROVIDER=mock
TRACEABILITY_FALLBACK_TO_MOCK=true

# SerpAPI key (required when TRACEABILITY_PROVIDER=serpapi)
SERPAPI_API_KEY=

# Cloudinary credentials (required when TRACEABILITY_PROVIDER=serpapi)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
